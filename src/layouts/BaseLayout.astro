---
import { ClientRouter } from 'astro:transitions'

import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'
import ThemeScript from '@/components/ThemeScript.astro'
import '@/styles/global.css'
import ThemeToggle from '@/components/ThemeToggle.astro'

interface Props {
  articleDate?: string
  description?: string
  image?: string
  title?: string
  type?: 'article' | 'website'
}

const {
  articleDate,
  description = 'Software Engineer. Terminal enthusiast. Problem solver.',
  image = '/og-image.png',
  title = 'Guilherme Rigotti',
  type = 'website',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const socialImageURL = new URL(image, Astro.site)
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta content='width=device-width, initial-scale=1.0' name='viewport' />
    <link href='/favicon/favicon.ico' rel='icon' sizes='any' />
    <link
      href='/favicon/favicon-32x32.png'
      rel='icon'
      sizes='32x32'
      type='image/png'
    />
    <link
      href='/favicon/favicon-16x16.png'
      rel='icon'
      sizes='16x16'
      type='image/png'
    />
    <link
      href='/favicon/apple-touch-icon.png'
      rel='apple-touch-icon'
      sizes='180x180'
    />
    <link href='/favicon/site.webmanifest' rel='manifest' />
    <meta content={Astro.generator} name='generator' />

    <!-- SEO Principal -->
    <title>{title}</title>
    <meta content={description} name='description' />
    <link href={canonicalURL} rel='canonical' />
    <meta content='#0a0a0a' name='theme-color' />
    <meta content='dark light' name='color-scheme' />

    <!-- Open Graph / Facebook -->
    <meta content={type} property='og:type' />
    <meta content={canonicalURL} property='og:url' />
    <meta content={title} property='og:title' />
    <meta content={description} property='og:description' />
    <meta content={socialImageURL} property='og:image' />
    {
      articleDate && (
        <meta content={articleDate} property='article:published_time' />
      )
    }

    <!-- Twitter -->
    <meta content='summary_large_image' property='twitter:card' />
    <meta content={canonicalURL} property='twitter:url' />
    <meta content={title} property='twitter:title' />
    <meta content={description} property='twitter:description' />
    <meta content={socialImageURL} property='twitter:image' />

    <!-- Fontes (JetBrains Mono é excelente para terminais) -->
    <link href='https://fonts.googleapis.com' rel='preconnect' />
    <link crossorigin href='https://fonts.gstatic.com' rel='preconnect' />
    <link
      href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap'
      rel='stylesheet'
    />

    <!-- RSS Feed -->
    <link
      href='/rss.xml'
      rel='alternate'
      title='Guilherme Rigotti - Blog'
      type='application/rss+xml'
    />

    <ClientRouter />
    <ThemeScript />
  </head>
  <body
    class='flex min-h-screen items-center justify-center bg-neutral-100 p-4 transition-colors sm:p-8 dark:bg-[#050505]'
  >
    <!-- Terminal Container -->
    <div
      class='relative w-full max-w-3xl overflow-hidden rounded-lg border border-neutral-300 bg-white shadow-2xl transition-colors dark:border-neutral-800 dark:bg-[#0a0a0a]'
    >
      <!-- Terminal Header (macOS Style) -->
      <div
        class='flex items-center justify-between border-b border-neutral-300 bg-neutral-100 px-4 py-3 transition-colors select-none dark:border-neutral-800 dark:bg-[#1a1a1a]'
      >
        <div aria-hidden='true' class='flex gap-2'>
          <div
            class='h-3 w-3 rounded-full bg-[#ff5f56] transition-colors hover:bg-[#ff5f56]/80'
          >
          </div>
          <div
            class='h-3 w-3 rounded-full bg-[#ffbd2e] transition-colors hover:bg-[#ffbd2e]/80'
          >
          </div>
          <div
            class='h-3 w-3 rounded-full bg-[#27c93f] transition-colors hover:bg-[#27c93f]/80'
          >
          </div>
        </div>
        <div
          class='flex gap-2 font-mono text-xs text-neutral-500 dark:text-neutral-500'
        >
          <span class='hidden sm:inline'>rigotti@dev:</span>
          <span class='text-neutral-600 dark:text-neutral-400'
            >{Astro.url.pathname}</span
          >
        </div>
        <ThemeToggle />
      </div>

      <!-- Content Area -->
      <div class='flex min-h-[600px] flex-col p-6 sm:p-8'>
        <Header />
        <main class='animate-in fade-in flex-1 py-6 duration-500'>
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
