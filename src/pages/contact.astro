---
import BaseLayout from '@/layouts/BaseLayout.astro'

const contacts = [
  {
    href: 'mailto:ggrigoti@gmail.com',
    name: 'Email',
    value: 'ggrigoti@gmail.com',
  },
  {
    href: 'https://github.com/rigottig',
    name: 'GitHub',
    value: 'github.com/rigottig',
  },
  {
    href: 'https://linkedin.com/in/rigottig',
    name: 'LinkedIn',
    value: 'linkedin.com/in/rigottig',
  },
]
---

<BaseLayout
  description='Get in touch with Guilherme Rigotti'
  title='Contact | Guilherme Rigotti'
>
  <div class='space-y-10'>
    <!-- Header -->
    <section>
      <h1
        class='mb-2 text-xl font-semibold text-neutral-900 dark:text-neutral-100'
      >
        Contact
      </h1>
      <p class='max-w-md text-sm text-neutral-600 dark:text-neutral-500'>
        I'm always open to discussing new projects, opportunities, or just
        having a chat about technology.
      </p>
    </section>

    <!-- Contact Methods -->
    <section>
      <h2
        class='mb-4 text-xs tracking-wider text-neutral-600 uppercase dark:text-neutral-500'
      >
        Get in touch
      </h2>
      <div class='space-y-3'>
        {
          contacts.map((contact) => (
            <a
              class='group -mx-2 flex items-center justify-between gap-4 rounded-md px-2 py-3 transition-colors hover:bg-neutral-200/50 dark:hover:bg-neutral-800/30'
              href={contact.href}
              rel={
                contact.href.startsWith('mailto')
                  ? undefined
                  : 'noopener noreferrer'
              }
              target={contact.href.startsWith('mailto') ? undefined : '_blank'}
            >
              <div>
                <span class='text-sm text-neutral-900 transition-colors group-hover:text-green-600 dark:text-neutral-200 dark:group-hover:text-green-400'>
                  {contact.name}
                </span>
                <p class='text-xs text-neutral-600 dark:text-neutral-500'>
                  {contact.value}
                </p>
              </div>
              <span class='text-neutral-600 transition-colors group-hover:text-green-600 dark:text-green-400'>
                →
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Availability -->
    <section>
      <h2
        class='mb-4 text-xs tracking-wider text-neutral-600 uppercase dark:text-neutral-500'
      >
        Availability
      </h2>
      <div
        class='rounded-lg border border-neutral-300 bg-neutral-100 p-4 dark:border-neutral-800 dark:bg-neutral-900/30'
      >
        <div class='mb-3 flex items-center gap-2'>
          <span
            class='h-2 w-2 animate-pulse rounded-full bg-green-600 dark:bg-green-500'
          ></span>
          <span class='text-sm text-green-600 dark:text-green-400'
            >Available for opportunities</span
          >
        </div>
        <div class='grid grid-cols-2 gap-4 text-xs'>
          <div>
            <span class='text-neutral-600 dark:text-neutral-500'>Location</span>
            <p class='text-neutral-800 dark:text-neutral-300'>Brazil (UTC-3)</p>
          </div>
          <div>
            <span class='text-neutral-600 dark:text-neutral-500'
              >Response time</span
            >
            <p class='text-neutral-800 dark:text-neutral-300'>
              Within 24 hours
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Email CTA -->
    <section class='pt-2'>
      <div
        class='rounded-lg border border-neutral-300 bg-neutral-100 p-4 dark:border-neutral-800 dark:bg-neutral-900/30'
      >
        <p class='mb-3 text-sm text-neutral-800 dark:text-neutral-300'>
          Let's work together!
        </p>
        <a
          class='inline-flex items-center gap-2 rounded-md bg-green-600 px-4 py-2 text-sm font-medium text-neutral-900 transition-colors hover:bg-green-700 dark:bg-green-500 dark:hover:bg-green-400'
          href='mailto:ggrigoti@gmail.com'
        >
          Send email
        </a>
      </div>
    </section>

    <!-- Back -->
    <nav class='border-t border-neutral-300 pt-4 dark:border-neutral-800'>
      <a
        class='text-sm text-neutral-600 transition-colors hover:text-green-600 dark:text-green-400 dark:text-neutral-500'
        href='/'
      >
        ← Back to home
      </a>
    </nav>
  </div>
</BaseLayout>
