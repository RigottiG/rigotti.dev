---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title='404 - Not Found | Guilherme Rigotti'>
  <div class='space-y-8'>
    <section class='space-y-4'>
      <h1 class='sr-only'>Page not found</h1>
      <div class='flex items-center gap-2 text-green-600 dark:text-green-500'>
        <span>➜</span>
        <span class='text-blue-400'>~</span>
        <span class='text-neutral-700 dark:text-neutral-300'
          >{Astro.url.pathname}</span
        >
      </div>

      <div class='space-y-4 border-l-2 border-red-500/50 pl-4'>
        <div class='space-y-2'>
          <p class='font-mono text-sm text-red-500 dark:text-red-400'>
            bash: {Astro.url.pathname}: No such file or directory
          </p>
          <p class='text-sm text-neutral-600 dark:text-neutral-400'>
            Error 404: The page you're looking for doesn't exist or has been
            moved.
          </p>
        </div>

        <div class='font-mono text-xs text-neutral-500 dark:text-neutral-600'>
          <p>Command failed with exit code: 404</p>
          <p class='mt-1'>Tip: Check the path and try again.</p>
        </div>
      </div>
    </section>

    <section class='space-y-2'>
      <div class='flex items-center gap-2 text-green-600 dark:text-green-500'>
        <span>➜</span>
        <span class='text-blue-400'>~</span>
        <span class='text-neutral-700 dark:text-neutral-300'
          >ls ./available-routes</span
        >
      </div>

      <div class='grid gap-2 pl-4 text-sm'>
        <a
          class='text-neutral-600 transition-colors hover:text-green-600 dark:text-neutral-400 dark:hover:text-green-400'
          href='/'
        >
          ~/home
        </a>
        <a
          class='text-neutral-600 transition-colors hover:text-green-600 dark:text-neutral-400 dark:hover:text-green-400'
          href='/blog'
        >
          ~/blog
        </a>
        <a
          class='text-neutral-600 transition-colors hover:text-green-600 dark:text-neutral-400 dark:hover:text-green-400'
          href='/about'
        >
          ~/about
        </a>
        <a
          class='text-neutral-600 transition-colors hover:text-green-600 dark:text-neutral-400 dark:hover:text-green-400'
          href='/contact'
        >
          ~/contact
        </a>
      </div>
    </section>

    <section class='pt-4'>
      <a
        class='inline-flex items-center gap-2 rounded-md bg-green-600 px-4 py-2 text-sm font-medium text-neutral-900 transition-colors hover:bg-green-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-500 dark:bg-green-500 dark:hover:bg-green-400'
        href='/'
      >
        cd ~
      </a>
    </section>
  </div>
</BaseLayout>
