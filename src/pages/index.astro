---
import { getCollection } from 'astro:content'

import Schema from '@/components/Schema.astro'
import Typewriter from '@/components/Typewriter.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getSlug } from '@/utils/date'

const allPosts = await getCollection('post')
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
---

<BaseLayout
  description='Senior Software Engineer from Brazil. Building scalable frontend applications and exploring system design.'
  title='Guilherme Rigotti — Software Engineer'
>
  <Schema type='Person' />

  <style>
    .terminal-output {
      opacity: 0;
      transform: translateY(8px);
      animation: fadeInUp 0.5s ease forwards;
    }

    .delay-1 {
      animation-delay: 0.8s;
    }
    .delay-2 {
      animation-delay: 1.4s;
    }
    .delay-3 {
      animation-delay: 2s;
    }
    .delay-4 {
      animation-delay: 2.6s;
    }
    .delay-5 {
      animation-delay: 3.2s;
    }

    @keyframes fadeInUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  <script>
    function resetAnimations() {
      document.querySelectorAll('.terminal-output').forEach((el) => {
        const htmlEl = el as HTMLElement
        htmlEl.style.animation = 'none'
        void htmlEl.offsetHeight
        htmlEl.style.animation = ''
      })
    }

    document.addEventListener('astro:page-load', resetAnimations)
  </script>

  <div class='space-y-8'>
    <!-- Intro Section -->
    <section class='space-y-4'>
      <Typewriter command='whoami' />

      <div
        class='terminal-output space-y-2 border-l-2 border-neutral-300 pl-4 delay-1 dark:border-neutral-800'
      >
        <h1 class='text-xl font-bold text-neutral-900 dark:text-neutral-100'>
          Guilherme Rigotti
        </h1>
        <p class='max-w-lg text-neutral-700 dark:text-neutral-400'>
          Senior Software Engineer from Brazil 🇧🇷. <br />
          Building scalable frontend applications and exploring the depths of system
          design.
        </p>
      </div>
    </section>

    <!-- Skills "Array" -->
    <section class='space-y-2'>
      <Typewriter command='ls ./skills' />
      <div
        class='terminal-output grid grid-cols-2 gap-2 pl-4 text-xs text-neutral-600 delay-2 sm:grid-cols-3 dark:text-neutral-400'
      >
        <span>typescript.ts</span>
        <span>react.jsx</span>
        <span>astro.build</span>
        <span>go.mod</span>
        <span>docker-compose.yml</span>
        <span>neovim.lua</span>
      </div>
    </section>

    <!-- Experience -->
    <section class='space-y-4'>
      <Typewriter command='cat ./experience.json' />

      <div class='terminal-output space-y-3 pl-4 delay-3'>
        <div class='flex items-start justify-between gap-4'>
          <div>
            <div class='flex items-center gap-2'>
              <span class='text-sm text-neutral-900 dark:text-neutral-200'
                >Axur</span
              >
              <span
                class='flex items-center gap-1.5 text-xs text-green-600 dark:text-green-400'
              >
                <span
                  class='h-1.5 w-1.5 animate-pulse rounded-full bg-green-500'
                ></span>
                now
              </span>
            </div>
            <span class='text-xs text-neutral-600 dark:text-neutral-500'
              >Senior Frontend Developer</span
            >
          </div>
          <span class='shrink-0 text-xs text-neutral-600'>2023 - Present</span>
        </div>

        <div class='flex items-start justify-between gap-4'>
          <div>
            <span class='text-sm text-neutral-900 dark:text-neutral-200'
              >CWI Software</span
            >
            <div class='text-xs text-neutral-600 dark:text-neutral-500'>
              Frontend Developer
            </div>
          </div>
          <span class='shrink-0 text-xs text-neutral-600'>2019 - 2023</span>
        </div>

        <div class='flex items-start justify-between gap-4'>
          <div>
            <span class='text-sm text-neutral-900 dark:text-neutral-200'
              >Mave Tecnologia</span
            >
            <div class='text-xs text-neutral-600 dark:text-neutral-500'>
              Fullstack Developer
            </div>
          </div>
          <span class='shrink-0 text-xs text-neutral-600'>2018 - 2019</span>
        </div>

        <a
          class='mt-2 inline-block text-sm text-green-600 transition-colors hover:text-green-300 dark:text-green-400'
          href='/about'
        >
          cat ./resume.pdf →
        </a>
      </div>
    </section>

    <!-- Latest Logs (Posts) -->
    {
      latestPosts.length > 0 && (
        <section class='space-y-4 pt-4'>
          <Typewriter command='tail -n 3 ./blog/logs' />

          <div class='terminal-output space-y-3 pl-4 delay-4'>
            {latestPosts.map((post) => {
              const postDate = new Date(post.data.date)
              return (
                <a class='group block' href={`/blog/post/${getSlug(post.id)}`}>
                  <div class='flex items-baseline justify-between gap-4'>
                    <span class='text-neutral-700 decoration-green-500/30 underline-offset-4 transition-all group-hover:text-green-600 group-hover:underline dark:text-neutral-300 dark:group-hover:text-green-400'>
                      {post.data.title}
                    </span>
                    <span class='shrink-0 font-mono text-xs text-neutral-600'>
                      {postDate.toISOString().split('T')[0]}
                    </span>
                  </div>
                </a>
              )
            })}
          </div>

          <a
            class='inline-block pl-4 text-sm text-green-600 transition-colors hover:text-green-300 dark:text-green-400'
            href='/blog'
          >
            ls -la ./blog →
          </a>
        </section>
      )
    }

    <!-- Contact CTA -->
    <section class='space-y-6 pt-4'>
      <Typewriter command='' delay={3000} />

      <div
        class='terminal-output rounded-lg border border-neutral-300 bg-neutral-100 p-4 pl-4 delay-5 dark:border-neutral-800 dark:bg-neutral-900/30'
      >
        <p class='mb-3 text-sm text-neutral-800 dark:text-neutral-300'>
          # Interested in working together?
        </p>
        <a
          class='inline-flex items-center gap-2 rounded-md bg-green-600 px-4 py-2 text-sm font-medium text-neutral-900 transition-colors hover:bg-green-700 dark:bg-green-500 dark:hover:bg-green-400'
          href='/contact'
        >
          ./contact --send
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
