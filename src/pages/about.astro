---
import BaseLayout from '@/layouts/BaseLayout.astro'

const experience = [
  {
    company: 'Axur',
    current: true,
    description:
      'Leading UI architecture and contributing across the stack (APIs, tooling, CI/CD) for cybersecurity products.',
    period: '2023 - Present',
    role: 'Senior Software Engineer',
  },
  {
    company: 'CWI Software',
    description:
      'Delivered client projects with React/Vue and collaborated closely with backend teams to ship end-to-end features.',
    period: '2019 - 2023',
    role: 'Software Engineer',
  },
  {
    company: 'Mave Tecnologia',
    description:
      'Built full-stack web applications with PHP/Laravel and JavaScript, from API design to UI delivery.',
    period: '2018 - 2019',
    role: 'Software Engineer',
  },
]

const skills = {
  backend: ['Node.js', 'Go', 'REST APIs', 'GraphQL', 'System Design'],
  frontend: [
    'React',
    'TypeScript',
    'Astro',
    'Vue.js',
    'Tailwind CSS',
    'UI Architecture',
  ],
  tools: ['Git', 'Neovim', 'Docker', 'Linux', 'CI/CD'],
}
---

<BaseLayout
  description='Learn more about Guilherme Rigotti — Software Engineer with 8+ years of experience across frontend and backend.'
  title='About | Guilherme Rigotti'
>
  <div class='space-y-10'>
    <!-- Intro -->
    <section>
      <h1
        class='mb-4 text-xl font-semibold text-neutral-900 dark:text-neutral-100'
      >
        About
      </h1>
      <div
        class='max-w-lg space-y-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400'
      >
        <p>
          I'm <span class='text-green-600 dark:text-green-400'
            >Guilherme Rigotti</span
          >, a Software Engineer from Brazil 🇧🇷 with <span
            class='text-neutral-700 dark:text-neutral-300'>8+ years</span
          > of experience building web applications.
        </p>
        <p>
          I’m strongest on the frontend (React, TypeScript, UI architecture),
          but I’m also comfortable on the backend (Node.js/Go, APIs, system
          design) — I like owning problems end-to-end.
        </p>
      </div>
    </section>

    <!-- Experience -->
    <section>
      <h2 class='mb-4 text-xs tracking-wider text-neutral-500 uppercase'>
        Experience
      </h2>
      <div class='space-y-6'>
        {
          experience.map((job) => (
            <div class='relative border-l border-neutral-300 pl-4 dark:border-neutral-800'>
              <div class='mb-1 flex items-start justify-between gap-4'>
                <div class='flex items-center gap-2'>
                  <span class='text-sm text-neutral-900 dark:text-neutral-200'>
                    {job.company}
                  </span>
                  {job.current && (
                    <span class='flex items-center gap-1.5 text-xs text-green-600 dark:text-green-400'>
                      <span class='h-1.5 w-1.5 animate-pulse rounded-full bg-green-500' />
                      now
                    </span>
                  )}
                </div>
                <span class='shrink-0 text-xs text-neutral-600'>
                  {job.period}
                </span>
              </div>
              <p class='mb-1 text-xs text-neutral-500'>{job.role}</p>
              <p class='text-xs text-neutral-600'>{job.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Skills -->
    <section>
      <h2 class='mb-4 text-xs tracking-wider text-neutral-500 uppercase'>
        Skills
      </h2>
      <div class='grid gap-6 sm:grid-cols-3'>
        <div>
          <h3 class='mb-2 text-xs text-neutral-600 dark:text-neutral-400'>
            Frontend
          </h3>
          <div class='flex flex-wrap gap-1.5'>
            {
              skills.frontend.map((skill) => (
                <span class='rounded border border-neutral-300 bg-neutral-200 px-2 py-1 text-xs text-neutral-700 dark:border-neutral-800 dark:bg-neutral-800/50 dark:text-neutral-400'>
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
        <div>
          <h3 class='mb-2 text-xs text-neutral-600 dark:text-neutral-400'>
            Backend
          </h3>
          <div class='flex flex-wrap gap-1.5'>
            {
              skills.backend.map((skill) => (
                <span class='rounded border border-neutral-300 bg-neutral-200 px-2 py-1 text-xs text-neutral-700 dark:border-neutral-800 dark:bg-neutral-800/50 dark:text-neutral-400'>
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
        <div>
          <h3 class='mb-2 text-xs text-neutral-600 dark:text-neutral-400'>
            Tools
          </h3>
          <div class='flex flex-wrap gap-1.5'>
            {
              skills.tools.map((skill) => (
                <span class='rounded border border-neutral-300 bg-neutral-200 px-2 py-1 text-xs text-neutral-700 dark:border-neutral-800 dark:bg-neutral-800/50 dark:text-neutral-400'>
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section>
      <h2 class='mb-4 text-xs tracking-wider text-neutral-500 uppercase'>
        Education
      </h2>
      <div class='space-y-4'>
        <div>
          <p class='text-sm text-neutral-900 dark:text-neutral-200'>
            Universidade La Salle
          </p>
          <p class='text-xs text-neutral-500'>
            Bachelor's degree, Computer Science · 2023 - 2027
          </p>
        </div>

        <div>
          <p class='text-sm text-neutral-900 dark:text-neutral-200'>
            IFSUL - Instituto Federal Sul-rio-grandense
          </p>
          <p class='text-xs text-neutral-500'>
            Technical degree, Information Technology · 2015 - 2018
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class='pt-4'>
      <div
        class='rounded-lg border border-neutral-300 bg-neutral-100 p-4 dark:border-neutral-800 dark:bg-neutral-900/30'
      >
        <p class='mb-3 text-sm text-neutral-800 dark:text-neutral-300'>
          Interested in working together?
        </p>
        <a
          class='inline-flex items-center gap-2 rounded-md bg-green-600 px-4 py-2 text-sm font-medium text-neutral-900 transition-colors hover:bg-green-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-500 dark:bg-green-500 dark:hover:bg-green-400'
          href='/contact'
        >
          Get in touch
        </a>
      </div>
    </section>

    <!-- Back -->
    <nav class='border-t border-neutral-300 pt-4 dark:border-neutral-800'>
      <a
        class='text-sm text-neutral-600 transition-colors hover:text-green-600 dark:text-green-400 dark:text-neutral-500'
        href='/'
      >
        ← Back to home
      </a>
    </nav>
  </div>
</BaseLayout>
