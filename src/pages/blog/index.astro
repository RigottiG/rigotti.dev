---
import { getCollection } from 'astro:content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import { formatDate, getSlug } from '@/utils/date'

const allPosts = await getCollection('post')
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)
---

<BaseLayout
  description='Thoughts and tutorials about software development'
  title='Blog | Guilherme Rigotti'
>
  <div class='space-y-8'>
    <!-- Header -->
    <header>
      <h1
        class='mb-2 text-xl font-semibold text-neutral-900 dark:text-neutral-100'
      >
        Blog
      </h1>
      <p class='text-sm text-neutral-600 dark:text-neutral-500'>
        Thoughts and tutorials about software development.
      </p>
    </header>

    <!-- Posts List -->
    <section>
      {
        sortedPosts.length > 0 ? (
          <div class='space-y-1'>
            {sortedPosts.map((post) => (
              <article class='group relative -mx-2 flex items-start justify-between gap-4 rounded-md px-2 py-3 transition-colors hover:bg-neutral-200/50 dark:hover:bg-neutral-800/30'>
                <div class='min-w-0 flex-1'>
                  <h2 class='text-sm text-neutral-900 transition-colors group-hover:text-green-600 dark:text-neutral-200 dark:group-hover:text-green-400'>
                    <a
                      class='static before:absolute before:inset-0'
                      href={`/blog/post/${getSlug(post.id)}`}
                    >
                      {post.data.title}
                    </a>
                  </h2>
                  {post.data.subtitle && (
                    <p class='mt-1 truncate text-xs text-neutral-600 dark:text-neutral-500'>
                      {post.data.subtitle}
                    </p>
                  )}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class='relative z-10 mt-2 flex flex-wrap gap-1.5'>
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <a
                          class='text-xs text-neutral-700 transition-colors hover:text-green-600 dark:text-neutral-600 dark:hover:text-green-400'
                          href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                        >
                          #{tag}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
                <time
                  class='shrink-0 pt-0.5 text-xs text-neutral-700 dark:text-neutral-600'
                  datetime={new Date(post.data.date).toISOString()}
                >
                  {formatDate(post.data.date, 'long')}
                </time>
              </article>
            ))}
          </div>
        ) : (
          <div class='py-12 text-center'>
            <p class='text-sm text-neutral-600 dark:text-neutral-500'>
              No posts yet.
            </p>
          </div>
        )
      }
    </section>

    <!-- Back -->
    <nav class='border-t border-neutral-300 pt-4 dark:border-neutral-800'>
      <a
        class='text-sm text-neutral-600 transition-colors hover:text-green-600 dark:text-green-400 dark:text-neutral-500'
        href='/'
      >
        ← Back to home
      </a>
    </nav>
  </div>
</BaseLayout>
