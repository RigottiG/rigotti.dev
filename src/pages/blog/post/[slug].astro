---
import { getCollection } from 'astro:content'
import { type CollectionEntry } from 'astro:content'

import Schema from '@/components/Schema.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { calculateReadingTime, formatDate, getSlug } from '@/utils/date'

type Props = {
  next: CollectionEntry<'post'> | null
  post: CollectionEntry<'post'>
  prev: CollectionEntry<'post'> | null
}

export async function getStaticPaths() {
  const posts = await getCollection('post')
  const sorted = posts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  )
  return sorted.map((post, index) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: {
      next: index > 0 ? sorted[index - 1] : null,
      post,
      prev: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }))
}

const { next, post, prev } = Astro.props
const { data, id, rendered } = post
const slug = id.replace(/\.md$/, '')
const { date, subtitle, tags, title } = data

const readingTime = calculateReadingTime(post.body || '')
---

<BaseLayout
  description={subtitle || `Blog post: ${title}`}
  title={`${title} | Guilherme Rigotti`}
>
  <article class='space-y-8'>
    <Schema data={data} slug={slug} type='BlogPosting' />
    <!-- Back -->
    <nav>
      <a
        class='text-sm text-neutral-600 transition-colors hover:text-green-600 dark:text-neutral-500 dark:hover:text-green-400'
        href='/blog'
      >
        ← Back to blog
      </a>
    </nav>

    <!-- Header -->
    <header class='space-y-4'>
      <div
        class='flex items-center gap-3 text-xs text-neutral-600 dark:text-neutral-500'
      >
        <time datetime={new Date(date).toISOString()}>
          {formatDate(date)}
        </time>
        <span>·</span>
        <span>{readingTime} min read</span>
      </div>

      <h1
        class='text-2xl leading-tight font-bold text-neutral-900 dark:text-neutral-100'
      >
        {title}
      </h1>

      {
        subtitle && (
          <p class='text-sm text-neutral-700 dark:text-neutral-400'>
            {subtitle}
          </p>
        )
      }

      {
        tags && tags.length > 0 && (
          <div class='flex flex-wrap gap-2 pt-2'>
            {tags.map((tag) => (
              <a
                class='text-xs text-neutral-700 transition-colors hover:text-green-600 dark:text-neutral-500 dark:hover:text-green-400'
                href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <!-- Divider -->
    <hr class='border-neutral-300 dark:border-neutral-800' />

    <!-- Content -->
    <div class='prose' set:html={rendered?.html} />

    <!-- Footer -->
    <footer class='border-t border-neutral-300 pt-8 dark:border-neutral-800'>
      <div class='flex items-center justify-between gap-4'>
        <div class='flex items-center gap-3'>
          <div
            class='flex h-10 w-10 items-center justify-center rounded-full bg-green-600/20 text-sm font-medium text-green-700 dark:bg-green-500/20 dark:text-green-400'
          >
            GR
          </div>
          <div>
            <p class='text-sm text-neutral-900 dark:text-neutral-200'>
              Guilherme Rigotti
            </p>
            <p class='text-xs text-neutral-700 dark:text-neutral-500'>
              Software Engineer
            </p>
          </div>
        </div>

        <a
          class='text-sm text-green-600 transition-colors hover:text-green-700 dark:text-green-400 dark:hover:text-green-300'
          href='/blog'
        >
          More posts →
        </a>
      </div>

      <!-- Prev / Next Navigation -->
      {
        (prev || next) && (
          <div class='mt-6 flex flex-col gap-3 border-t border-neutral-300 pt-6 sm:flex-row sm:justify-between dark:border-neutral-800'>
            {prev ? (
              <a
                class='group flex flex-col gap-1 rounded-md px-2 py-1.5 transition-colors hover:bg-neutral-200/50 dark:hover:bg-neutral-800/30'
                href={`/blog/post/${getSlug(prev.id)}`}
              >
                <span class='text-xs text-neutral-500'>← Previous</span>
                <span class='text-sm text-neutral-700 transition-colors group-hover:text-green-600 dark:text-neutral-300 dark:group-hover:text-green-400'>
                  {prev.data.title}
                </span>
              </a>
            ) : (
              <div />
            )}
            {next ? (
              <a
                class='group flex flex-col items-end gap-1 rounded-md px-2 py-1.5 text-right transition-colors hover:bg-neutral-200/50 dark:hover:bg-neutral-800/30'
                href={`/blog/post/${getSlug(next.id)}`}
              >
                <span class='text-xs text-neutral-500'>Next →</span>
                <span class='text-sm text-neutral-700 transition-colors group-hover:text-green-600 dark:text-neutral-300 dark:group-hover:text-green-400'>
                  {next.data.title}
                </span>
              </a>
            ) : (
              <div />
            )}
          </div>
        )
      }
    </footer>
  </article>
</BaseLayout>
