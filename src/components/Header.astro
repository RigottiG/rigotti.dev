---
const navItems = [
  { cmd: 'cd ~', href: '/', label: '~/home' },
  { cmd: 'cd blog', href: '/blog', label: '~/blog' },
  { cmd: 'cat about', href: '/about', label: '~/about' },
  { cmd: 'mail', href: '/contact', label: '~/contact' },
]

const currentPath = Astro.url.pathname
---

<header class='mb-8 font-mono text-sm'>
  <nav class='flex flex-wrap gap-x-6 gap-y-2'>
    {
      navItems.map((item) => {
        const isActive =
          currentPath === item.href ||
          (item.href !== '/' && currentPath.startsWith(item.href))
        return (
          <a
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'group relative transition-colors',
              isActive
                ? 'font-bold text-green-600 dark:text-green-400'
                : 'text-neutral-600 hover:text-neutral-900 dark:text-neutral-500 dark:hover:text-neutral-300',
            ]}
            href={item.href}
          >
            <span class='absolute -left-3 text-green-600 opacity-0 transition-opacity group-hover:opacity-100 dark:text-green-500'>
              &gt;
            </span>
            {isActive ? `./${item.label.replace('~/', '')}` : item.label}
          </a>
        )
      })
    }
  </nav>
  <div
    class='mt-4 h-px w-full bg-neutral-300 transition-colors dark:bg-neutral-800'
  >
  </div>
</header>
