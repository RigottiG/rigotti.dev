---
import { type CollectionEntry } from 'astro:content'

interface Props {
  data?: CollectionEntry<'post'>['data']
  slug?: string
  type: 'BlogPosting' | 'Person'
}

const { data, slug, type } = Astro.props

let schema = {}

if (type === 'Person') {
  schema = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    jobTitle: 'Senior Software Engineer',
    name: 'Guilherme Rigotti',
    sameAs: ['https://github.com/rigottig', 'https://linkedin.com/in/rigottig'],
    url: 'https://rigotti.dev',
  }
} else if (type === 'BlogPosting' && data && slug) {
  schema = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    author: {
      '@type': 'Person',
      name: 'Guilherme Rigotti',
    },
    datePublished: data.date.toISOString(),
    description: data.subtitle,
    headline: data.title,
    url: `https://rigotti.dev/blog/post/${slug}`,
  }
}
---

<script
  is:inline
  set:html={JSON.stringify(schema)}
  type='application/ld+json'
/>
