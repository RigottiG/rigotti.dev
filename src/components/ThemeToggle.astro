<button
  aria-label='Toggle theme'
  class='rounded p-2 text-neutral-700 transition-colors hover:bg-neutral-300 dark:text-neutral-300 dark:hover:bg-neutral-700'
  id='theme-toggle'
  title='Toggle theme'
>
  <svg
    class='hidden h-5 w-5'
    fill='none'
    id='theme-icon-light'
    stroke='currentColor'
    viewBox='0 0 24 24'
  >
    <path
      d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'
      stroke-linecap='round'
      stroke-linejoin='round'
      stroke-width='2'
    ></path>
  </svg>
  <svg
    class='hidden h-5 w-5'
    fill='none'
    id='theme-icon-dark'
    stroke='currentColor'
    viewBox='0 0 24 24'
  >
    <path
      d='M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'
      stroke-linecap='round'
      stroke-linejoin='round'
      stroke-width='2'
    ></path>
  </svg>
</button>
